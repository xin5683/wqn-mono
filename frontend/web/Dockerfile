# Frontend image for Wrong-Question-Notebook (Next.js 16, standalone output).
#
#   Build:  docker build -t wqn-frontend .
#   Run:    docker run --rm -p 3000:3000 wqn-frontend
#
# `output: 'standalone'` (set in next.config.ts) produces a self-contained
# server.js under .next/standalone, so the runtime image needs no node_modules.
#
# NOTE: Next.js bakes rewrite destinations into .next/routes-manifest.json at
# BUILD time, so WQN_API_BASE_URL is a build ARG (default targets the `backend`
# service on the shared docker network). The same var is also needed at RUNTIME
# by the proxy (proxy.ts) and server-side fetches, so it is set as an env var in
# the runner stage and can be overridden via compose.

# ---- dependencies ----
FROM node:22-slim AS deps
WORKDIR /app
# No git repo inside the build → skip husky's prepare hook.
ENV HUSKY=0
COPY package.json package-lock.json ./
# Domestic npm mirror (npmmirror) for fast installs in China; overridable via
# build arg (set to empty for the official registry).
# `npm install` (not `npm ci`) tolerates lockfile drift — the committed lock was
# generated by an older npm and is missing @swc/helpers@0.5.23. Re-run
# `npm install` locally + commit to restore reproducible `npm ci`.
ARG NPM_REGISTRY=https://registry.npmmirror.com/
RUN if [ -n "$NPM_REGISTRY" ]; then npm config set registry "$NPM_REGISTRY"; fi \
 && npm install --no-audit --no-fund

# ---- builder ----
FROM node:22-slim AS builder
WORKDIR /app
ENV HUSKY=0 \
    NEXT_TELEMETRY_DISABLED=1
COPY --from=deps /app/node_modules ./node_modules
COPY . .
# Build-time config (baked into the standalone output / routes manifest):
ARG WQN_API_BASE_URL=http://backend:8080
ARG SITE_URL=http://localhost:3000
ENV WQN_API_BASE_URL=${WQN_API_BASE_URL} \
    SITE_URL=${SITE_URL}
RUN npm run build

# ---- runtime ----
FROM node:22-slim AS runner
WORKDIR /app
ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0 \
    # Runtime config for proxy.ts + server-side fetches (defaults match the
    # values baked at build; override via compose for a different backend):
    WQN_API_BASE_URL=http://backend:8080 \
    SITE_URL=http://localhost:3000
# Standalone server.js + static client assets + public + i18n messages.
COPY --from=builder --chown=node:node /app/.next/standalone ./
COPY --from=builder --chown=node:node /app/.next/static ./.next/static
COPY --from=builder --chown=node:node /app/public ./public
COPY --from=builder --chown=node:node /app/messages ./messages
USER node
EXPOSE 3000
CMD ["node", "server.js"]
