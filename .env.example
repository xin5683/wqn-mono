# ---- Postgres ----
POSTGRES_USER=wqn
POSTGRES_PASSWORD=wqn_password
POSTGRES_DB=wqn
# Host port to expose Postgres on (optional, for local tooling like psql):
POSTGRES_PORT=5432

# ---- Backend API ----
# IMPORTANT: generate a strong secret, e.g. `openssl rand -base64 48`
AUTH_JWT_SECRET=change-me-please-run-openssl-rand-base64-48
# Host port to expose the API on:
BACKEND_PORT=8080
# Comma-separated list of allowed browser origins:
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Set to true when serving the frontend over HTTPS:
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_SECONDS=2592000
DATABASE_MAX_CONNECTIONS=10

# ---- Frontend (Next.js) ----
# Baked into the routes manifest at BUILD time; also used at runtime by proxy.ts.
WQN_API_BASE_URL=http://backend:8080
SITE_URL=http://localhost:3000
FRONTEND_PORT=3000

# ---- Optional integrations ----
# GEMINI_API_KEY=
# CRON_SECRET=
# LOCAL_STORAGE_SCAN_COMMAND=
